# Copy to .env and fill in. All values can also be passed as CLI flags.

# Required: TMDB v3 API key (32 hex chars) OR a v4 read access token.
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Optional: official MyAnimeList API Client ID for better anime matching.
# Register an app at https://myanimelist.net/apiconfig (no OAuth needed for
# search). Left blank, the free keyless Jikan API is used instead.
MAL_CLIENT_ID=

# Storage roots (optional). All default to DATA_DIR (/data in Docker), so a
# single mounted volume works out of the box. Set these to split storage onto
# separate volumes — remember to mount each one in docker-compose too.
#   CONFIG_DIR — settings.json, overrides.json
#   DATA_DIR   — library.db + run history (your tracker data)
#   MEDIA_DIR  — TMDB/MAL/Crunchyroll lookup cache (regenerable)
# CONFIG_DIR=
# DATA_DIR=
# MEDIA_DIR=

# Only for docker-compose.tailscale.yml (join the container to your tailnet).
# Create one at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
