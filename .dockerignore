__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Secrets and local config
.env
.env.*

# Runtime data volume, caches, and generated files
data/
tmdb_cache.json
mal_cache.json
crunchyroll_history.json
overrides.json
overrides.template.json
migration_report.json
